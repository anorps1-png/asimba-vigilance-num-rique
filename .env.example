# ─── Configuration Supabase (ASIMBA) ────────────────────────────────────────
# Copiez ce fichier en `.env` puis renseignez vos valeurs (tableau de bord
# Supabase → Project Settings → API). Ne committez jamais le fichier `.env`.

# --- Côté client (exposé au navigateur, donc UNIQUEMENT des clés publiques) ---
# URL du projet, ex. https://votreref.supabase.co
VITE_SUPABASE_URL=
# Clé publiable / anon (jamais la service_role ici)
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- Côté serveur (jamais exposé au navigateur) ---
# Reprend les mêmes URL / clé publiable pour les fonctions serveur et la
# validation de session (middleware d'auth).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Clé service_role : accès admin qui CONTOURNE les RLS. Strictement secrète,
# utilisée uniquement dans les fichiers *.server.ts.
SUPABASE_SERVICE_ROLE_KEY=
